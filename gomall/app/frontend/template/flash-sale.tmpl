{{ define "flash-sale" }}
    {{ template "header" . }}
    
    <style>
        .flash-sale-banner {
            background: linear-gradient(135deg, #ff416c, #ff4b2b);
            border-radius: var(--border-radius);
            padding: 20px;
            color: white;
            margin-bottom: 16px;
            text-align: center;
        }
        .flash-sale-banner h2 {
            font-size: 24px;
            margin: 0 0 8px 0;
            font-weight: 600;
        }
        .flash-sale-banner p {
            font-size: 14px;
            margin: 0;
            opacity: 0.9;
        }
        .product-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            padding: 0;
        }
        @media (min-width: 576px) {
            .product-grid { grid-template-columns: repeat(3, 1fr); }
        }
        @media (min-width: 992px) {
            .product-grid { grid-template-columns: repeat(4, 1fr); gap: 12px; }
        }
        @media (min-width: 1200px) {
            .product-grid { grid-template-columns: repeat(5, 1fr); }
        }
        .product-card {
            background: var(--card-bg);
            border-radius: var(--border-radius-sm);
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: block;
            transition: all 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        }
        .product-img-wrapper {
            width: 100%;
            padding-top: 100%;
            position: relative;
            background: #f8f8f8;
            overflow: hidden;
        }
        .product-img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .product-tag {
            position: absolute;
            top: 8px;
            left: 8px;
            background: linear-gradient(135deg, #ff416c, #ff4b2b);
            color: white;
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 10px;
            z-index: 1;
            font-weight: 500;
            animation: flashPulse 1.5s ease-in-out infinite;
        }
        @keyframes flashPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.8; }
        }
        .product-info { padding: 10px; }
        .product-name {
            font-size: 13px;
            color: var(--text-primary);
            line-height: 1.4;
            height: 36px;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            margin-bottom: 6px;
        }
        .product-price-row {
            display: flex;
            align-items: baseline;
            gap: 4px;
        }
        .product-price {
            font-size: 16px;
            color: #ff4d4f;
            font-weight: 600;
        }
        .product-price::before { content: '¥'; font-size: 12px; }
        .product-original-price {
            font-size: 11px;
            color: #999;
            text-decoration: line-through;
        }
        .product-discount-label {
            font-size: 10px;
            color: #ff4d4f;
            background: #fff0f0;
            padding: 1px 4px;
            border-radius: 2px;
            margin-left: 4px;
        }
        .product-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 6px;
            font-size: 11px;
            color: var(--text-secondary);
        }
        .product-sales { display: flex; align-items: center; gap: 2px; }
        .product-sales i { color: #ff6034; font-size: 10px; }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: var(--card-bg);
            border-radius: var(--border-radius);
        }
        .empty-state i {
            font-size: 48px;
            color: #ddd;
            margin-bottom: 16px;
        }
        .empty-state h4 {
            color: var(--text-secondary);
            margin-bottom: 8px;
        }
        .countdown-timer {
            background: rgba(255,255,255,0.2);
            padding: 8px 16px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 12px;
        }
        .countdown-box {
            background: rgba(0,0,0,0.2);
            padding: 4px 8px;
            border-radius: 4px;
            font-weight: 600;
            min-width: 32px;
            text-align: center;
        }
    </style>

    <div class="flash-sale-banner">
        <h2><i class="fas fa-bolt me-2"></i>限时特惠</h2>
        <p>精选好物，超值优惠等你来抢</p>
    </div>

    {{ if $.items }}
    <div class="product-grid">
        {{ range $index, $item := $.items }}
        <a href="/product?id={{ $item.Id }}" class="product-card">
            <div class="product-img-wrapper">
                {{ if le $item.Stock 0 }}
                <div class="sold-out-overlay" style="position: absolute; inset: 0; background: rgba(120, 120, 120, 0.55); z-index: 2; display: flex; align-items: center; justify-content: center;">
                    <span style="background: rgba(0,0,0,0.6); color: white; padding: 8px 16px; border-radius: 20px;">已售罄</span>
                </div>
                {{ else }}
                <span class="product-tag"><i class="fas fa-bolt"></i> 限时特惠</span>
                {{ end }}
                <img src="{{ $item.Picture }}" class="product-img" alt="{{ $item.Name }}" loading="lazy">
            </div>
            <div class="product-info">
                <div class="product-name">{{ $item.Name }}</div>
                <div class="product-price-row">
                    <span class="product-price">{{ printf "%.2f" $item.ActualPrice }}</span>
                    {{ if gt $item.OriginalPrice 0.0 }}
                    <span class="product-original-price">{{ printf "%.2f" $item.OriginalPrice }}</span>
                    {{ else if gt $item.Price 0.0 }}
                    <span class="product-original-price">{{ printf "%.2f" $item.Price }}</span>
                    {{ end }}
                    {{ if $item.DiscountLabel }}
                    <span class="product-discount-label">{{ $item.DiscountLabel }}</span>
                    {{ end }}
                </div>
                <div class="product-meta">
                    <span class="{{if le $item.Stock 0}}text-danger{{else if lt $item.Stock 10}}text-warning{{end}}">
                        {{if le $item.Stock 0}}已售罄{{else if lt $item.Stock 10}}仅剩{{$item.Stock}}件{{else}}库存充足{{end}}
                    </span>
                    <span class="product-sales"><i class="fas fa-fire"></i> {{ $item.Sales }}人付款</span>
                </div>
            </div>
        </a>
        {{ end }}
    </div>
    {{ else }}
    <div class="empty-state">
        <i class="fas fa-clock"></i>
        <h4>暂无限时特惠商品</h4>
        <p>敬请期待更多优惠活动</p>
        <a href="/" class="btn btn-primary mt-3" style="background: linear-gradient(135deg, #ff416c, #ff4b2b); border: none; border-radius: 20px; padding: 8px 24px;">返回首页</a>
    </div>
    {{ end }}

    {{ template "footer" . }}
{{ end }}
