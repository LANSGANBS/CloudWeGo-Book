{{ define "order" }}
    {{ template "header" . }}
    
    <style>
        .order-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 16px;
        }
        .order-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }
        .order-title {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-primary);
        }
        .sort-indicator {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--text-secondary);
            background: var(--card-bg);
            padding: 6px 12px;
            border-radius: 16px;
        }
        .sort-indicator i {
            color: var(--primary-color);
        }
        .order-card {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            margin-bottom: 16px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }
        .order-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            background: linear-gradient(135deg, rgba(255,96,52,0.05), rgba(255,140,66,0.05));
            border-bottom: 1px solid #f0f0f0;
        }
        .order-meta {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .order-id {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-primary);
        }
        .order-time {
            font-size: 12px;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .order-time i {
            font-size: 11px;
        }
        .order-status {
            font-size: 12px;
            padding: 4px 10px;
            border-radius: 12px;
            background: linear-gradient(135deg, #52c41a, #73d13d);
            color: white;
        }
        .order-items {
            padding: 12px 16px;
        }
        .order-item {
            display: flex;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f5f5f5;
        }
        .order-item:last-child {
            border-bottom: none;
        }
        .order-item-img {
            width: 60px;
            height: 60px;
            border-radius: 8px;
            object-fit: cover;
            margin-right: 12px;
            background: #f8f8f8;
        }
        .order-item-info {
            flex: 1;
        }
        .order-item-name {
            font-size: 14px;
            color: var(--text-primary);
            margin-bottom: 4px;
        }
        .order-item-qty {
            font-size: 12px;
            color: var(--text-secondary);
        }
        .order-item-cost {
            font-size: 14px;
            font-weight: 500;
            color: #ff4d4f;
        }
        .order-item-cost::before {
            content: '¥';
            font-size: 12px;
        }
        .order-footer {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 12px 16px;
            background: #fafafa;
            border-top: 1px solid #f0f0f0;
        }
        .order-total {
            font-size: 14px;
            color: var(--text-primary);
        }
        .order-total-amount {
            font-size: 18px;
            font-weight: 600;
            color: #ff4d4f;
            margin-left: 8px;
        }
        .order-total-amount::before {
            content: '¥';
            font-size: 14px;
        }
        .empty-orders {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-secondary);
        }
        .empty-orders i {
            font-size: 48px;
            color: #ddd;
            margin-bottom: 16px;
        }
        .empty-orders p {
            font-size: 16px;
            margin-bottom: 8px;
        }
        .empty-orders a {
            color: var(--primary-color);
            text-decoration: none;
        }
    </style>

    <div class="order-container">
        <div class="order-header">
            <h1 class="order-title"><i class="fas fa-box me-2"></i>我的订单</h1>
            <div class="sort-indicator">
                <i class="fas fa-clock"></i>
                <span>按最近时间排序</span>
            </div>
        </div>

        {{ if $.orders }}
            {{ range $.orders }}
            <div class="order-card">
                <div class="order-card-header">
                    <div class="order-meta">
                        <span class="order-id">订单号: {{.OrderId}}</span>
                        <span class="order-time">
                            <i class="fas fa-calendar-alt"></i>
                            {{.CreatedDate}}
                        </span>
                    </div>
                    <span class="order-status">已完成</span>
                </div>
                <div class="order-items">
                    {{ range .Items }}
                    <div class="order-item">
                        <img src="{{ .Picture }}" class="order-item-img" alt="{{ .ProductName }}">
                        <div class="order-item-info">
                            <div class="order-item-name">{{ .ProductName }}</div>
                            <div class="order-item-qty">x {{ .Qty }}</div>
                        </div>
                        <div class="order-item-cost">{{ printf "%.2f" .Cost }}</div>
                    </div>
                    {{ end }}
                </div>
                <div class="order-footer">
                    <span class="order-total">订单总额:</span>
                    <span class="order-total-amount">{{ printf "%.2f" .Cost }}</span>
                </div>
            </div>
            {{ end }}
        {{ else }}
            <div class="empty-orders">
                <i class="fas fa-box-open"></i>
                <p>暂无订单</p>
                <a href="/">去购物</a>
            </div>
        {{ end }}
    </div>

    {{ template "footer" . }}
{{ end }}