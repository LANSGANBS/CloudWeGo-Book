{{ define "product" }}
    {{ template "header" . }}
    
    <style>
        .product-detail {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            overflow: hidden;
            margin-bottom: 16px;
        }
        .product-detail-body {
            display: flex;
            flex-direction: column;
            gap: 20px;
            padding: 16px;
        }
        @media (min-width: 992px) {
            .product-detail-body {
                flex-direction: row;
                padding: 24px;
            }
        }
        .product-gallery {
            flex: 1;
            position: relative;
        }
        .product-main-img {
            width: 100%;
            aspect-ratio: 1;
            object-fit: cover;
            border-radius: var(--border-radius-sm);
            background: #f8f8f8;
        }
        .product-info-section {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .product-title {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 8px;
            line-height: 1.4;
        }
        .product-desc {
            font-size: 14px;
            color: var(--text-secondary);
            line-height: 1.6;
            margin-bottom: 16px;
        }
        .product-price-section {
            background: linear-gradient(135deg, rgba(255,96,52,0.1), rgba(255,140,66,0.1));
            border-radius: var(--border-radius-sm);
            padding: 16px;
            margin-bottom: 16px;
        }
        .product-price-label {
            font-size: 12px;
            color: var(--text-secondary);
            margin-bottom: 4px;
        }
        .product-price-value {
            font-size: 28px;
            color: #ff4d4f;
            font-weight: 600;
        }
        .product-price-value::before { content: '¥'; font-size: 18px; }
        .product-meta-info {
            display: flex;
            gap: 16px;
            margin-bottom: 16px;
            font-size: 13px;
            color: var(--text-secondary);
        }
        .product-meta-item {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .product-meta-item i { color: #ff6034; }
        .quantity-section {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }
        .quantity-label {
            font-size: 14px;
            color: var(--text-primary);
        }
        .quantity-input {
            display: flex;
            align-items: center;
            border: 1px solid #e8e8e8;
            border-radius: 8px;
            overflow: hidden;
            transition: border-color 0.2s;
        }
        .quantity-input:focus-within {
            border-color: var(--primary-color);
        }
        .quantity-input.error {
            border-color: #ff4d4f;
        }
        .quantity-btn {
            width: 36px;
            height: 36px;
            border: none;
            background: #f5f5f5;
            color: var(--text-primary);
            font-size: 16px;
            cursor: pointer;
            transition: background 0.2s;
        }
        .quantity-btn:hover { background: #e8e8e8; }
        .quantity-btn:disabled {
            color: #ccc;
            cursor: not-allowed;
        }
        .quantity-value {
            width: 60px;
            height: 36px;
            border: none;
            text-align: center;
            font-size: 14px;
            outline: none;
            background: white;
        }
        .quantity-value::-webkit-outer-spin-button,
        .quantity-value::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .quantity-value[type=number] {
            -moz-appearance: textfield;
        }
        .quantity-hint {
            font-size: 12px;
            color: var(--text-secondary);
            margin-bottom: 16px;
        }
        .quantity-error {
            font-size: 12px;
            color: #ff4d4f;
            margin-bottom: 12px;
            display: none;
        }
        .quantity-error.show {
            display: block;
        }
        .total-price-section {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 16px;
            padding: 12px;
            background: #fafafa;
            border-radius: 8px;
        }
        .total-price-label {
            font-size: 14px;
            color: var(--text-secondary);
        }
        .total-price-value {
            font-size: 20px;
            color: #ff4d4f;
            font-weight: 600;
        }
        .total-price-value::before { content: '¥'; font-size: 14px; }
        .action-buttons {
            display: flex;
            gap: 12px;
        }
        .btn-cart {
            flex: 1;
            padding: 12px 24px;
            border: 2px solid var(--primary-color);
            background: white;
            color: var(--primary-color);
            border-radius: 24px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-cart:hover {
            background: rgba(255,96,52,0.1);
        }
        .btn-buy {
            flex: 1;
            padding: 12px 24px;
            border: none;
            background: linear-gradient(135deg, #ff6034, #ff8c42);
            color: white;
            border-radius: 24px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-buy:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(255,96,52,0.3);
        }
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 13px;
            margin-bottom: 12px;
        }
        .back-link:hover { color: var(--primary-color); }
        
        /* 售罄遮罩样式 */
        .sold-out-overlay {
            position: absolute;
            inset: 0;
            background: rgba(120, 120, 120, 0.55);
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--border-radius-sm);
        }
        .sold-out-stamp {
            position: relative;
            width: 120px;
            height: 120px;
            transform: rotate(-15deg);
            opacity: 0.92;
        }
        .stamp-border {
            position: absolute;
            inset: 0;
            border: 4px solid rgba(255, 255, 255, 0.9);
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 0 2px rgba(255,255,255,0.2), inset 0 0 0 6px rgba(255,255,255,0.1);
        }
        .stamp-text {
            font-size: 22px;
            font-weight: bold;
            color: #FFFFFF;
            letter-spacing: 2px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.4);
        }
        .stamp-subtext {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.85);
            letter-spacing: 1px;
            margin-top: 2px;
        }
        .stamp-waves {
            position: absolute;
            right: -18px;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        .stamp-wave {
            width: 20px;
            height: 5px;
            background: transparent;
            border-radius: 50%;
            border: 2px solid rgba(255, 255, 255, 0.85);
            border-bottom: none;
        }
        .stamp-wave:nth-child(2) { width: 16px; margin-left: 2px; }
        .stamp-wave:nth-child(3) { width: 12px; margin-left: 4px; }
    </style>

    <a href="/" class="back-link">
        <i class="fas fa-arrow-left"></i> 返回首页
    </a>

    <div class="product-detail">
        <div class="product-detail-body">
            <div class="product-gallery">
                {{ if le .item.Stock 0 }}
                <div class="sold-out-overlay">
                    <div class="sold-out-stamp">
                        <div class="stamp-border">
                            <div class="stamp-text">已售罄</div>
                            <div class="stamp-subtext">SOLD OUT</div>
                        </div>
                        <div class="stamp-waves">
                            <div class="stamp-wave"></div>
                            <div class="stamp-wave"></div>
                            <div class="stamp-wave"></div>
                        </div>
                    </div>
                </div>
                {{ end }}
                <img src="{{ .item.Picture }}" class="product-main-img" alt="{{ .item.Name }}">
            </div>
            <div class="product-info-section">
                <h1 class="product-title">{{ .item.Name }}</h1>
                <p class="product-desc">{{ .item.Description }}</p>
                
                <div class="product-price-section">
                    <div class="product-price-label">商品价格</div>
                    <div class="product-price-value" id="unitPrice">{{ printf "%.2f" .item.Price }}</div>
                </div>

                <div class="product-meta-info">
                    <div class="product-meta-item">
                        <i class="fas fa-box"></i>
                        <span>库存: <span id="stockCount">{{ .item.Stock }}</span>件</span>
                    </div>
                    <div class="product-meta-item">
                        <i class="fas fa-fire"></i>
                        <span>{{ .item.Sales }}人付款</span>
                    </div>
                    <div class="product-meta-item">
                        <i class="fas fa-truck"></i>
                        <span>免费配送</span>
                    </div>
                </div>
                
                {{ if le .item.Stock 0 }}
                <div class="alert alert-danger" style="margin-bottom: 16px;">
                    <i class="fas fa-exclamation-triangle me-2"></i>该商品已售罄，暂时无法购买
                </div>
                {{ end }}

                <form action="/cart" method="post" id="cartForm">
                    <input type="hidden" value="{{ .item.Id }}" name="productId">
                    
                    <div class="quantity-section">
                        <span class="quantity-label">数量</span>
                        <div class="quantity-input" id="qtyInputWrapper">
                            <button type="button" class="quantity-btn" id="btnMinus" onclick="changeQty(-1)">-</button>
                            <input type="number" class="quantity-value" id="productNum" name="productNum" value="1" min="1" max="999">
                            <button type="button" class="quantity-btn" id="btnPlus" onclick="changeQty(1)">+</button>
                        </div>
                    </div>
                    <div class="quantity-hint">单次限购 999 件，最小购买 1 件</div>
                    <div class="quantity-error" id="qtyError"></div>

                    <div class="total-price-section">
                        <span class="total-price-label">小计:</span>
                        <span class="total-price-value" id="totalPrice">{{ printf "%.2f" .item.Price }}</span>
                    </div>

                    <div class="action-buttons">
                        <button type="submit" class="btn-buy">
                            <i class="fas fa-shopping-cart me-2"></i>加入购物车
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        var unitPrice = {{ .item.Price }};
        var minQty = 1;
        var maxQty = 999;
        var stock = {{ .item.Stock }};
        
        if (stock > 0 && stock < maxQty) {
            maxQty = stock;
        }

        var qtyInput = document.getElementById('productNum');
        var qtyError = document.getElementById('qtyError');
        var qtyWrapper = document.getElementById('qtyInputWrapper');
        var totalPrice = document.getElementById('totalPrice');
        var btnMinus = document.getElementById('btnMinus');
        var btnPlus = document.getElementById('btnPlus');
        
        {{ if le .item.Stock 0 }}
        document.getElementById('cartForm').innerHTML = '<div class="alert alert-warning"><i class="fas fa-bell me-2"></i>商品已售罄，您可以<a href="/">浏览其他商品</a></div>';
        {{ end }}

        function showError(message) {
            qtyError.textContent = message;
            qtyError.classList.add('show');
            qtyWrapper.classList.add('error');
        }

        function hideError() {
            qtyError.classList.remove('show');
            qtyWrapper.classList.remove('error');
        }

        function updateTotalPrice() {
            var qty = parseInt(qtyInput.value) || 1;
            var total = unitPrice * qty;
            totalPrice.textContent = total.toFixed(2);
        }

        function updateButtons() {
            var qty = parseInt(qtyInput.value) || 1;
            btnMinus.disabled = qty <= minQty;
            btnPlus.disabled = qty >= maxQty;
        }

        function validateQty(value) {
            var qty = parseInt(value);
            
            if (isNaN(qty) || value.trim() === '') {
                showError('请输入有效的数量');
                return minQty;
            }
            
            if (qty < minQty) {
                showError('购买数量不能小于 ' + minQty);
                return minQty;
            }
            
            if (qty > maxQty) {
                showError('单次最多购买 ' + maxQty + ' 件');
                return maxQty;
            }
            
            if (qty > stock) {
                showError('库存不足，当前库存 ' + stock + ' 件');
                return stock;
            }
            
            if (!Number.isInteger(parseFloat(value))) {
                showError('购买数量必须为整数');
                return Math.floor(qty);
            }
            
            hideError();
            return qty;
        }

        function changeQty(delta) {
            var currentQty = parseInt(qtyInput.value) || 1;
            var newQty = currentQty + delta;
            
            if (newQty < minQty) {
                newQty = minQty;
                showError('购买数量不能小于 ' + minQty);
            } else if (newQty > maxQty) {
                newQty = maxQty;
                showError('单次最多购买 ' + maxQty + ' 件');
            } else {
                hideError();
            }
            
            qtyInput.value = newQty;
            updateTotalPrice();
            updateButtons();
        }

        qtyInput.addEventListener('input', function() {
            this.value = this.value.replace(/[^\d]/g, '');
            
            if (this.value !== '') {
                var qty = parseInt(this.value);
                if (qty > maxQty) {
                    this.value = maxQty;
                }
            }
            
            updateTotalPrice();
            updateButtons();
        });

        qtyInput.addEventListener('blur', function() {
            if (this.value === '' || this.value === '0') {
                this.value = minQty;
                showError('购买数量不能小于 ' + minQty);
            } else {
                var validatedQty = validateQty(this.value);
                this.value = validatedQty;
            }
            
            updateTotalPrice();
            updateButtons();
        });

        qtyInput.addEventListener('focus', function() {
            hideError();
        });

        document.getElementById('cartForm').addEventListener('submit', function(e) {
            var validatedQty = validateQty(qtyInput.value);
            qtyInput.value = validatedQty;
            
            if (validatedQty < minQty || validatedQty > maxQty) {
                e.preventDefault();
                return false;
            }
        });

        updateTotalPrice();
        updateButtons();
    </script>

    {{ template "footer" . }}
{{ end }}