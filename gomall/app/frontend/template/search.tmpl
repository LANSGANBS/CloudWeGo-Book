{{ define "search" }}
    {{ template "header" . }}
    
    <style>
        .product-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            padding: 0;
        }
        @media (min-width: 576px) {
            .product-grid { grid-template-columns: repeat(3, 1fr); }
        }
        @media (min-width: 992px) {
            .product-grid { grid-template-columns: repeat(4, 1fr); gap: 12px; }
        }
        @media (min-width: 1200px) {
            .product-grid { grid-template-columns: repeat(5, 1fr); }
        }
        .product-card {
            background: var(--card-bg);
            border-radius: var(--border-radius-sm);
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: block;
            transition: all 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        }
        .product-img-wrapper {
            width: 100%;
            padding-top: 100%;
            position: relative;
            background: #f8f8f8;
            overflow: hidden;
        }
        .product-img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .product-tag {
            position: absolute;
            top: 8px;
            left: 8px;
            background: linear-gradient(135deg, #ff6034, #ff8c42);
            color: white;
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 10px;
            z-index: 1;
            font-weight: 500;
        }
        .product-tag.flash-sale { 
            background: linear-gradient(135deg, #ff416c, #ff4b2b); 
            animation: flashPulse 1.5s ease-in-out infinite;
        }
        @keyframes flashPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.8; }
        }
        .product-original-price {
            font-size: 11px;
            color: #999;
            text-decoration: line-through;
        }
        .product-discount-label {
            font-size: 10px;
            color: #ff4d4f;
            background: #fff0f0;
            padding: 1px 4px;
            border-radius: 2px;
            margin-left: 4px;
        }
        .product-info { padding: 10px; }
        .product-name {
            font-size: 13px;
            color: var(--text-primary);
            line-height: 1.4;
            height: 36px;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            margin-bottom: 6px;
        }
        .product-price {
            font-size: 16px;
            color: #ff4d4f;
            font-weight: 600;
        }
        .product-price::before { content: '¥'; font-size: 12px; }
        .product-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 6px;
            font-size: 11px;
            color: var(--text-secondary);
        }
        .product-sales { display: flex; align-items: center; gap: 2px; }
        .product-sales i { color: #ff6034; font-size: 10px; }
        
        /* 售罄遮罩样式 */
        .sold-out-overlay {
            position: absolute;
            inset: 0;
            background: rgba(120, 120, 120, 0.55);
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .sold-out-stamp {
            position: relative;
            width: 70px;
            height: 70px;
            transform: rotate(-15deg);
            opacity: 0.92;
        }
        .stamp-border {
            position: absolute;
            inset: 0;
            border: 2.5px solid rgba(255, 255, 255, 0.9);
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 0 1px rgba(255,255,255,0.2), inset 0 0 0 3px rgba(255,255,255,0.1);
        }
        .stamp-text {
            font-size: 14px;
            font-weight: bold;
            color: #FFFFFF;
            letter-spacing: 1px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.4);
        }
        .stamp-subtext {
            font-size: 7px;
            color: rgba(255, 255, 255, 0.85);
            letter-spacing: 0.5px;
            margin-top: 1px;
        }
        .stamp-waves {
            position: absolute;
            right: -12px;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            flex-direction: column;
            gap: 3px;
        }
        .stamp-wave {
            width: 14px;
            height: 3px;
            background: transparent;
            border-radius: 50%;
            border: 1.5px solid rgba(255, 255, 255, 0.85);
            border-bottom: none;
        }
        .stamp-wave:nth-child(2) { width: 12px; margin-left: 1px; }
        .stamp-wave:nth-child(3) { width: 10px; margin-left: 2px; }
        
        .search-info {
            background: var(--card-bg);
            border-radius: var(--border-radius-sm);
            padding: 12px 16px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .search-keyword {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .search-keyword span {
            background: linear-gradient(135deg, #ff6034, #ff8c42);
            color: white;
            padding: 4px 12px;
            border-radius: 16px;
            font-size: 14px;
        }
        .search-count {
            font-size: 13px;
            color: var(--text-secondary);
        }
        .no-result {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-secondary);
        }
        .no-result i {
            font-size: 48px;
            color: #ddd;
            margin-bottom: 16px;
        }
        .no-result p {
            font-size: 16px;
            margin-bottom: 8px;
        }
        .no-result a {
            color: var(--primary-color);
            text-decoration: none;
        }
    </style>

    {{ if .q }}
    <div class="search-info">
        <div class="search-keyword">
            <i class="fas fa-search" style="color: var(--text-secondary);"></i>
            <span>{{ .q }}</span>
            <a href="/" style="color: var(--text-secondary); text-decoration: none; margin-left: 8px;">
                <i class="fas fa-times-circle"></i>
            </a>
        </div>
        <div class="search-count">找到 {{ len $.items }} 件商品</div>
    </div>
    {{ end }}

    {{ if $.items }}
    <div class="product-grid">
        {{ range $index, $item := $.items }}
        <a href="/product?id={{ $item.Id }}" class="product-card">
            <div class="product-img-wrapper">
                {{ if le $item.Stock 0 }}
                <div class="sold-out-overlay">
                    <div class="sold-out-stamp">
                        <div class="stamp-border">
                            <div class="stamp-text">已售罄</div>
                            <div class="stamp-subtext">SOLD OUT</div>
                        </div>
                        <div class="stamp-waves">
                            <div class="stamp-wave"></div>
                            <div class="stamp-wave"></div>
                            <div class="stamp-wave"></div>
                        </div>
                    </div>
                </div>
                {{ else if eq $item.DiscountStatus 2 }}
                <span class="product-tag flash-sale"><i class="fas fa-bolt"></i> 限时特惠</span>
                {{ else if eq $item.DiscountStatus 4 }}
                <span class="product-tag" style="background: linear-gradient(135deg, #f093fb, #f5576c);"><i class="fas fa-tag"></i> {{ $item.DiscountLabel }}</span>
                {{ else }}
                <span class="product-tag">搜索结果</span>
                {{ end }}
                <img src="{{ $item.Picture }}" class="product-img" alt="{{ $item.Name }}" loading="lazy">
            </div>
            <div class="product-info">
                <div class="product-name">{{ $item.Name }}</div>
                <div class="product-price-row">
                    {{ if or (eq $item.DiscountStatus 2) (eq $item.DiscountStatus 4) }}
                    <span class="product-price">{{ printf "%.2f" $item.ActualPrice }}</span>
                    {{ if gt $item.OriginalPrice 0.0 }}
                    <span class="product-original-price">{{ printf "%.2f" $item.OriginalPrice }}</span>
                    {{ else if gt $item.Price 0.0 }}
                    <span class="product-original-price">{{ printf "%.2f" $item.Price }}</span>
                    {{ end }}
                    {{ if $item.DiscountLabel }}
                    <span class="product-discount-label">{{ $item.DiscountLabel }}</span>
                    {{ end }}
                    {{ else }}
                    <span class="product-price">{{ printf "%.2f" $item.Price }}</span>
                    {{ end }}
                </div>
                <div class="product-meta">
                    <span class="{{if le $item.Stock 0}}text-danger{{else if lt $item.Stock 10}}text-warning{{end}}">
                        {{if le $item.Stock 0}}已售罄{{else if lt $item.Stock 10}}仅剩{{$item.Stock}}件{{else}}库存充足{{end}}
                    </span>
                    <span class="product-sales"><i class="fas fa-fire"></i> {{ $item.Sales }}人付款</span>
                </div>
            </div>
        </a>
        {{ end }}
    </div>
    {{ else }}
    <div class="no-result">
        <i class="fas fa-search"></i>
        <p>未找到相关商品</p>
        <a href="/">返回首页</a>
    </div>
    {{ end }}

    {{ template "footer" . }}
{{ end }}
